@warlord_size = 200
entity = {
    name = "aot_warlord_entity"
    pdxmesh = "aot_warlord_frame_mesh"
    default_state = "idle"
    state = {
        name = "idle" animation_blend_time = 0.25
    }
    state = {
        name = "moving" animation_blend_time = 0.25
    }
    state = {
        name = "death" animation_blend_time = 0.0 looping = no
        event = { time = 13.2 node = "part1" particle = "juggernaut_explosion_particle" sound = { soundeffect = ship_destroyed } }
    }
    scale = 3
    game_data = {
        size = @warlord_size
        emissive_recolor_crunch = 5.0
    }
}
